<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
          onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="HyperlinkRemoverTab"
           getLabel="GetTabLabel">
        <group id="RemoveGroup"
               getLabel="GetRemoveGroupLabel">
          <button id="RemoveHyperlinksBtn"
                  onAction="OnRemoveHyperlinks"
                  getLabel="GetRemovePageLabel"
                  getScreentip="GetRemovePageScreentip"
                  getSupertip="GetRemovePageSupertip"
                  size="large" />
          <button id="RemoveSelectionHyperlinksBtn"
                  onAction="OnRemoveSelectionHyperlinks"
                  getLabel="GetRemoveSelectionLabel"
                  getScreentip="GetRemoveSelectionScreentip"
                  getSupertip="GetRemoveSelectionSupertip"
                  size="normal" />
        </group>
        <group id="AutoRemoveGroup"
               getLabel="GetAutoRemoveGroupLabel">
          <toggleButton id="AutoRemoveToggle"
                        onAction="OnToggleAutoRemove"
                        getPressed="GetAutoRemovePressed"
                        getLabel="GetAutoRemoveLabel"
                        getScreentip="GetAutoRemoveScreentip"
                        size="large" />
          <editBox id="IntervalEditBox"
                   onChange="OnIntervalChange"
                   getText="GetIntervalText"
                   getLabel="GetIntervalLabel"
                   getScreentip="GetIntervalScreentip"
                   sizeString="999999"
                   maxLength="6" />
        </group>
        <group id="ClipboardGroup"
               getLabel="GetClipboardGroupLabel">
          <toggleButton id="ClipboardToggle"
                        onAction="OnToggleClipboard"
                        getPressed="GetClipboardPressed"
                        getLabel="GetClipboardLabel"
                        getScreentip="GetClipboardScreentip"
                        size="large" />
          <editBox id="ClipboardIntervalEditBox"
                   onChange="OnClipboardIntervalChange"
                   getText="GetClipboardIntervalText"
                   getLabel="GetClipboardIntervalLabel"
                   getScreentip="GetClipboardIntervalScreentip"
                   sizeString="999999"
                   maxLength="6" />
        </group>
      </tab>
    </tabs>
  </ribbon>
  <contextMenus>
    <contextMenu idMso="ContextMenuText">
      <menuSeparator id="SepHyperlinkStart" />
      <button id="CtxRemoveSelectionHyperlinks"
              onAction="OnRemoveSelectionHyperlinks"
              getLabel="GetRemoveSelectionLabel"
              getScreentip="GetRemoveSelectionScreentip" />
      <button id="CtxRemovePageHyperlinks"
              onAction="OnRemoveHyperlinks"
              getLabel="GetRemovePageLabel"
              getScreentip="GetRemovePageScreentip" />
      <button id="CtxCopyCleanText"
              onAction="OnCopyCleanText"
              getLabel="GetCopyCleanTextLabel"
              getScreentip="GetCopyCleanTextScreentip" />
    </contextMenu>
    <contextMenu idMso="ContextMenuPage">
      <menuSeparator id="SepHyperlinkPageStart" />
      <button id="CtxRemovePageHyperlinks2"
              onAction="OnRemoveHyperlinks"
              getLabel="GetRemovePageLabel"
              getScreentip="GetRemovePageScreentip" />
    </contextMenu>
  </contextMenus>
</customUI>
